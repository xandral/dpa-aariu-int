# Database
DATABASE_URL=postgresql+asyncpg://wpim:wpim@localhost:5432/wpim

# AI provider API key (OpenAI, Anthropic, etc.)
AI_API_KEY=sk-...

# Scheduler
SCHEDULER_INTERVAL=60

# Defaults for new URLs
DEFAULT_FREQUENCY=3600
DEFAULT_DIFF_THRESHOLD_OK=5.0
DEFAULT_DIFF_THRESHOLD_ALERT=50.0
DEFAULT_COSINE_THRESHOLD_OK=0.95
DEFAULT_COSINE_THRESHOLD_ALERT=0.5

# HTTP fetch
FETCH_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
